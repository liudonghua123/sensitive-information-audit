# Example environment configuration
# Copy this file to .env and update the values

# Application Settings
PROJECT_NAME="Sensitive Info Audit"
API_V1_STR="/api/v1"

# Security Settings
# IMPORTANT: Change this to a secure random string in production
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY="changethis-please-use-a-secure-random-string"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database Settings
# SQLite (default)
DATABASE_URL="sqlite+aiosqlite:///./audit.db"

# PostgreSQL example:
# DATABASE_URL="postgresql+asyncpg://user:password@localhost:5432/audit_db"

# MySQL example:
# DATABASE_URL="mysql+aiomysql://user:password@localhost:3306/audit_db"
